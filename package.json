{
  "name": "topclanker",
  "version": "1.0.0",
  "description": "AI Agent Rankings - No bullshit, just data",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./src/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "build:11ty": "eleventy",
    "build": "npm run build:css && npm run build:11ty",
    "watch": "eleventy --serve",
    "start": "npm run watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "markdown-it": "^14.1.1",
    "tailwindcss": "^3.4.0"
  }
}
