<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title if title else site.name }}</title>
    <meta name="description" content="{{ description if description else site.description }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="{{ ogType if ogType else 'website' }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:title" content="{{ title if title else site.name }}">
    <meta property="og:description" content="{{ description if description else site.description }}">
    <meta property="og:image" content="{{ site.url }}/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="{{ site.name }}">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ site.url }}{{ page.url }}">
    <meta property="twitter:title" content="{{ title if title else site.name }}">
    <meta property="twitter:description" content="{{ description if description else site.description }}">
    <meta property="twitter:image" content="{{ site.url }}/og-image.png">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <link rel="stylesheet" href="/output.css">
    <link rel="stylesheet" href="/style.css">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7245948824993108" crossorigin="anonymous"></script>
</head>
<body class="bg-gray-50 text-gray-900">

    <!-- Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-2">
                    <a href="/" class="text-2xl font-bold text-blue-600">TopClanker</a>
                    <span class="text-sm text-gray-500 hidden sm:inline">AI Agent Rankings</span>
                </div>
                <div class="flex space-x-6">
                    <a href="/#rankings" class="text-gray-700 hover:text-blue-600 font-medium">Rankings</a>
                    <a href="/#categories" class="text-gray-700 hover:text-blue-600 font-medium hidden sm:inline">Categories</a>
                    <a href="/methodology.html" class="text-gray-700 hover:text-blue-600 font-medium">Methodology</a>
                    <a href="/blog/" class="text-gray-700 hover:text-blue-600 font-medium">Blog</a>
                    <a href="/#learn" class="text-gray-700 hover:text-blue-600 font-medium hidden sm:inline">Learn</a>
                </div>
            </div>
        </nav>
    </header>

    {{ content | safe }}

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div>
                    <h4 class="text-white font-bold mb-4">TopClanker</h4>
                    <p class="text-sm">Objective AI agent rankings. No hype, just performance.</p>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-4">Quick Links</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/#rankings" class="hover:text-white">Rankings</a></li>
                        <li><a href="/#categories" class="hover:text-white">Categories</a></li>
                        <li><a href="/blog/" class="hover:text-white">Blog</a></li>
                        <li><a href="/privacy.html" class="hover:text-white">Privacy</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-4">Contact</h4>
                    <p class="text-sm">Want to submit your agent for ranking?<br>Email: rankings@topclanker.com</p>
                </div>
            </div>
            <div class="border-t border-gray-800 mt-8 pt-8 text-sm text-center">
                <p>&copy; {{ site.year }} TopClanker. Built with zero bullshit.</p>
            </div>
        </div>
    </footer>

</body>
</html>
